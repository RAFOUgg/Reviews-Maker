// Templates sauvegardés par l'utilisateur
model SavedTemplate {
  id     String @id @default(uuid())
  userId String // Propriétaire
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informations du template
  name         String // Nom personnalisé
  description  String? // Description
  templateType String // "compact", "detailed", "complete", "custom"
  format       String // "1:1", "16:9", "9:16", "A4"

  // Configuration (même structure que Template.config)
  config String // JSON: { pages, theme, colors, fonts, zones }

  // Prévisualisation
  thumbnail String? // URL de la miniature générée

  // Utilisation
  useCount   Int       @default(0) // Nombre d'utilisations
  lastUsedAt DateTime?

  // Tags personnalisés
  tags String? // JSON: ["portrait", "minimaliste", "pro"]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([templateType])
  @@index([format])
  @@index([useCount])
  @@map("saved_templates")
}

// Filigranes (watermarks) personnalisés
model Watermark {
  id     String @id @default(uuid())
  userId String // Propriétaire
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informations
  name        String // Nom du filigrane
  description String?

  // Type
  type String // "text", "image", "logo"

  // Contenu
  content  String? // Texte du filigrane (si type=text)
  imageUrl String? // URL de l'image (si type=image ou logo)

  // Style
  style String // JSON: { font, size, color, opacity, position, rotation }

  // Statut
  isDefault Boolean @default(false) // Filigrane par défaut

  // Utilisation
  useCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isDefault])
  @@map("watermarks")
}

// Données sauvegardées pour réutilisation rapide
model SavedData {
  id     String @id @default(uuid())
  userId String // Propriétaire
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Type de données
  dataType String // "cultivar", "pipeline", "recipe", "effect_profile", "custom"

  // Informations
  name        String // Nom de la donnée sauvegardée
  description String? // Description

  // Contenu
  data String // JSON: données complètes

  // Catégorie
  category String? // Pour organiser (ex: "mes_cultivars", "pipelines_culture", etc.)

  // Tags
  tags String? // JSON: ["bio", "indoor", "pheno_hunt"]

  // Utilisation
  useCount   Int       @default(0)
  lastUsedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dataType])
  @@index([category])
  @@map("saved_data")
}

// ====================
// STATISTIQUES UTILISATEUR
// ====================

// Statistiques globales utilisateur
model UserStats {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Statistiques reviews
  totalReviews   Int @default(0) // Total reviews créées
  publicReviews  Int @default(0) // Reviews publiques
  privateReviews Int @default(0) // Reviews privées

  // Répartition par type
  flowerReviews      Int @default(0)
  hashReviews        Int @default(0)
  concentrateReviews Int @default(0)
  edibleReviews      Int @default(0)

  // Exports
  totalExports Int @default(0) // Nombre d'exports réalisés
  exportsPNG   Int @default(0)
  exportsJPEG  Int @default(0)
  exportsPDF   Int @default(0)
  exportsSVG   Int @default(0)
  exportsCSV   Int @default(0)
  exportsJSON  Int @default(0)
  exportsHTML  Int @default(0)

  // Engagement (reviews publiques uniquement)
  totalLikes    Int @default(0) // Likes reçus
  totalViews    Int @default(0) // Vues
  totalShares   Int @default(0) // Partages
  totalComments Int @default(0) // Commentaires

  // Activité
  lastReviewDate DateTime? // Date dernière review
  lastExportDate DateTime? // Date dernier export

  // Producteurs : statistiques cultures
  totalCultures Int?   @default(0) // Nombre de cultures
  totalYield    Float? // Rendement total (g)
  avgYield      Float? // Rendement moyen par culture

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_stats")
}

// Vues des reviews (tracking anonyme)
model ReviewView {
  id       String @id @default(uuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  // Optionnel: userId si connecté
  userId String?

  // Tracking
  ipAddress String? // Hash de l'IP pour analytics
  userAgent String?
  referer   String? // D'où vient le visiteur

  // Géolocalisation (optionnel)
  country String?
  region  String?

  // Timestamp
  viewedAt DateTime @default(now())

  @@index([reviewId])
  @@index([userId])
  @@index([viewedAt])
  @@map("review_views")
}

// Commentaires sur les reviews publiques
model ReviewComment {
  id       String @id @default(uuid())
  reviewId String
  userId   String

  // Contenu
  content String // Texte du commentaire (max 1000 caractères)

  // Modération
  isEdited     Boolean   @default(false)
  editedAt     DateTime?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deleteReason String?

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId])
  @@index([userId])
  @@index([createdAt])
  @@map("review_comments")
}

// Modèle VerificationCode (codes email 6 chiffres)
model VerificationCode {
  id        String   @id @default(uuid())
  email     String // Email destinataire
  code      String // Code 6 chiffres (ex: "A3B7K9")
  type      String // "login" | "register" | "reset_password"
  expiresAt DateTime // Expiration 10 minutes
  attempts  Int      @default(0) // Nombre de tentatives (max 5)
  verified  Boolean  @default(false) // Marqué vérifié après validation
  createdAt DateTime @default(now())

  @@index([email, type])
  @@index([code])
  @@index([expiresAt])
  @@map("verification_codes")
}

// Modèle Export (suivi des exports)
model Export {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String? // Optionnel: review exportée
  format    String // "png", "jpeg", "pdf", "svg", "gif", "csv", "json", "html"
  quality   String // "standard", "high", "ultra"
  createdAt DateTime @default(now())

  // Figement (Chantier 6 traçabilité) : copie des données réellement rendues au moment de l'export,
  // pour pouvoir attester plus tard "cet export correspondait à la review telle qu'elle était à cette
  // date" même si la review a changé depuis. Optionnels : seuls les exports du rapport de traçabilité
  // les renseignent, un export image classique (png/jpeg) reste un simple compteur d'usage comme avant.
  snapshotData String? // JSON: reviewData adapté (buildExportReviewData) tel que rendu à l'export
  contentHash  String? // sha256(snapshotData), recalculable côté client pour détecter une dérive

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("exports")
}

// Modèle ExportTemplate (templates d'export personnalisés)
model ExportTemplate {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String // Nom du template
  description String?
  isCustom    Boolean  @default(true) // true pour templates personnalisés
  isDefault   Boolean  @default(false) // template par défaut pour l'utilisateur
  config      String // JSON: configuration complète du template
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isCustom])
  @@index([isDefault])
  @@map("export_templates")
}

// Modèle ExportConfiguration (configurations d'export sauvegardées)
model ExportConfiguration {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("userExportConfigs", fields: [userId], references: [id], onDelete: Cascade)

  reviewId String? // Linked review si config spécifique (nullable)
  review   Review? @relation("reviewExportConfigs", fields: [reviewId], references: [id], onDelete: SetNull)

  // Nom et description
  name        String  @default("Ma Configuration")
  description String?
  isDefault   Boolean @default(false)

  // Template et format
  templateName String @default("modernCompact")
  format       String @default("1:1")
  ratio        String @default("1:1")

  // Couleurs et apparence (JSON strings)
  colors     String // JSON: { background, accent, textPrimary, textSecondary, border }
  typography String // JSON: { fontFamily, fontSize, fontWeight, lineHeight }

  // Configuration des contenus visibles
  contentModules String // JSON: { title: true, images: true, aromas: true, effects: true, ... }

  // Branding
  watermark String? // JSON: { visible, type, content, position, size, opacity, rotation, color }
  branding  String? // JSON: { logo, filigrane, customFont }

  // Image settings
  imageSettings String? // JSON: { selectedIndex, effects, border, qualityHighRes }

  // Métadonnées
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  // Statistics
  useCount Int @default(0)

  @@unique([userId, name])
  @@index([userId])
  @@index([reviewId])
  @@map("export_configurations")
}

// Project : regroupement libre des groupes/préréglages par campagne/production
// (ex: "Récolte Été 2026") — permet de trier/filtrer les UserPreset par projet.
model Project {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String? // couleur de badge pour l'UI (hex), optionnelle
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  presets UserPreset[]

  @@index([userId])
  @@map("projects")
}

// Modèle UserPreset (préréglages de champs pipeline pour l'utilisateur) — couvre les
// champs individuels ("field"), les groupes de champs ("grouped") et les configurations
// complètes de pipeline avec pré-assignations groupe↔cellule ("setup"). Utilisable aussi
// bien depuis un pipeline (Culture/Curing/Séparation/Extraction) que depuis la Chaîne de
// production, qui partage les mêmes schémas de champs (cf. chainCellPipelines.js).
model UserPreset {
  id           Int       @id @default(autoincrement())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String // Nom du préréglage
  description  String? // Description optionnelle
  type         String // "field" (champ individuel), "grouped" (groupe de champs), "pipeline" (réservé, inutilisé), "setup" (config complète + pré-assignations)
  pipelineType String? // "culture" | "curing" | "separation" | "extraction" — nullable pour un futur préréglage "toutes pipelines"
  emoji        String? // Icône affichée en liste, sans avoir à parser `data`
  tags         String? // JSON: string[] — même convention que SavedData.tags
  projectId    Int?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isArchived   Boolean   @default(false) // suppression douce — ne jamais casser un Setup qui référence ce groupe
  data         String // JSON: données du préréglage (voir presets.js pour le contrat exact par type)
  useCount     Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([userId, type, pipelineType])
  @@index([userId, projectId])
  @@map("user_presets")
}

// ==================== GENETICS/PHENOHUNT SYSTEM ====================

// Modèle GeneticTree (arbres généalogiques complets)
model GeneticTree {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation("userGeneticTrees", fields: [userId], references: [id], onDelete: Cascade)
  name        String // Nom du projet/arbre
  description String? // Description optionnelle
  projectType String  @default("phenohunt") // "phenohunt", "selection", "crossing", "hunt"
  isPublic    Boolean @default(false)
  shareCode   String? @unique // Code unique pour partage public
  sharedWith  String? // JSON: array of userId who have access

  // Relations
  nodes         GenNode[]
  edges         GenEdge[]
  annotations   GenAnnotation[]
  flowerReviews FlowerReview[]  @relation("flowerReviewTree")

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectType])
  @@index([isPublic])
  @@map("genetic_trees")
}

// Modèle GenNode (nœuds du graphe généalogique)
model GenNode {
  id     String      @id @default(uuid())
  treeId String
  tree   GeneticTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  // Données du cultivar
  cultivarName String // Nom du cultivar (copie pour performance)

  // Visualisation
  position String // JSON: {x: number, y: number}
  color    String  @default("#FF6B9D") // Couleur du nœud
  image    String? // URL image du cultivar

  // Données génétiques
  genetics String? // JSON: {breeder, type, ratio, notes}
  notes    String? // Notes supplémentaires

  // Référence applicative vers la FlowerReview dont ce nœud a été créé (glisser-déposer d'une
  // fiche, "Créer un arbre à partir de cette fleur", "Importer cette fleur à un arbre") — permet
  // un raccourci "Éditer la review" direct depuis le nœud. Pas de FK Prisma (même pattern que
  // ChainNode.reviewId) : nullable, best-effort, jamais garanti (nœuds créés à vide notamment).
  sourceReviewId String?

  // Photos/vidéos illustrant ce nœud dans l'arbre — même mécanisme que ChainNode.media.
  // JSON: Array<{ id, url, type: 'photo'|'video', filename, caption, uploadedAt }>
  media String @default("[]")

  // Relations sortantes et entrantes
  childEdges  GenEdge[]       @relation("parentNode")
  parentEdges GenEdge[]       @relation("childNode")
  annotations GenAnnotation[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId])
  @@map("gen_nodes")
}

// Modèle GenEdge (arêtes du graphe - relations parent/enfant)
model GenEdge {
  id     String      @id @default(uuid())
  treeId String
  tree   GeneticTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  parentNodeId String
  parentNode   GenNode @relation("parentNode", fields: [parentNodeId], references: [id], onDelete: Cascade)

  childNodeId String
  childNode   GenNode @relation("childNode", fields: [childNodeId], references: [id], onDelete: Cascade)

  // Métadonnées de relation
  relationshipType  String  @default("parent") // "parent", "pollen_donor", "sibling", "clone", "mutation", "pairing"
  pollinationMethod String? // "open", "controlled-manual", "isolation-selected-male", "pollination-bag",
  // "brush", "pollen-collection-storage", "male-flower-harvest",
  // "selfing-inversion", "chemical-feminization"
  notes             String? // Notes supplémentaires

  // Point de courbure optionnel (coordonnées canvas) permettant de décaler la liaison à la main
  // plutôt que de suivre une ligne droite systématique. Null = ligne droite par défaut.
  waypointX Float?
  waypointY Float?

  // Côté du nœud (parent/enfant) où l'utilisateur a choisi d'ancrer manuellement l'extrémité de
  // la liaison ("top"|"bottom"|"left"|"right"), en glissant la poignée d'extrémité vers un autre
  // point d'accroche du nœud. Null = accroche automatique "flottante" (calculée sur le bord réel
  // du nœud selon sa position relative, cf. graph-canvas/floatingEdgeUtils.js) — le choix manuel
  // n'est appliqué que si l'utilisateur l'a explicitement fixé.
  sourceHandle String?
  targetHandle String?

  // Photos/vidéos illustrant cette relation — même mécanisme que GenNode.media.
  media String @default("[]")

  annotations GenAnnotation[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentNodeId, childNodeId, relationshipType]) // Empêche les doublons
  @@index([treeId])
  @@index([parentNodeId])
  @@index([childNodeId])
  @@map("gen_edges")
}

// Modèle ProductionChain (chaîne de production — graphe liant plusieurs fiches
// techniques de types différents avec les données de transformation sur les liaisons)
model ProductionChain {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation("userProductionChains", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean @default(false)
  shareCode   String? @unique

  nodes       ChainNode[]
  edges       ChainEdge[]
  annotations ChainAnnotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@map("production_chains")
}

// Modèle ChainNode (nœud référençant une review existante d'un des 4 types —
// référence applicative reviewType+reviewId, pas de FK Prisma possible car
// les reviews vivent dans 4 tables spécifiques différentes)
model ChainNode {
  id      String          @id @default(uuid())
  chainId String
  chain   ProductionChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  reviewType String // "flower" | "hash" | "concentrate" | "edible" — clé normalisée interne
  // Nullable (comme GenNode.sourceReviewId côté PhenoHunt) : "Tout détacher" sur un lien cassé
  // (review supprimée) met reviewId à null plutôt que de forcer la suppression du nœud —
  // il garde sa position/couleur/notes et reste réassignable via "Changer la review liée".
  reviewId   String? // = Review.id
  label      String // copie du nom au moment de l'ajout (fallback si review supprimée)
  image      String? // copie de la première photo au moment de l'ajout (même raison que label)

  position String // JSON: {x: number, y: number}
  color    String @default("#10b981")

  // Cellules de pipeline (culture/curing/separation/extraction) importées depuis une fiche
  // technique et attachées à ce nœud — snapshot au moment de l'import, pas une référence live.
  // JSON: Array<{ id, sourceReviewId, sourceReviewType, sourceLabel, pipelineType, pipelineLabel, timestamp, cellLabel, data, attachedAt }>
  cellData String @default("[]")

  // Photos/vidéos illustrant ce produit dans le canvas (cf. routes/media-upload.js, 200 Mo max).
  // JSON: Array<{ id, url, type: 'photo'|'video', filename, caption, uploadedAt }>
  media String @default("[]")

  sourceEdges ChainEdge[]       @relation("chainSourceNode")
  targetEdges ChainEdge[]       @relation("chainTargetNode")
  annotations ChainAnnotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chainId, reviewType, reviewId])
  @@index([chainId])
  @@index([reviewType, reviewId])
  @@map("chain_nodes")
}

// Modèle ChainEdge (arête portant les métadonnées de transformation entre deux
// fiches techniques : technique utilisée, date, notes)
model ChainEdge {
  id      String          @id @default(uuid())
  chainId String
  chain   ProductionChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  // Extrémité source : soit un nœud produit (sourceNodeId), soit une bulle épinglée — média ou
  // carte de données (sourceAnnotationId) — jamais les deux à la fois. Idem côté cible. Une vraie
  // contrainte FK polymorphique n'existant pas nativement en Prisma/SQL, la mutuelle exclusion et
  // l'existence de l'extrémité choisie sont validées côté route (cf. utils/chainEdgeEndpoints.js),
  // pas en base. sourceNodeId/targetNodeId restent la forme la plus courante (liaison produit↔produit)
  // donc nullable seulement pour permettre l'alternative bulle, pas parce qu'une liaison peut être
  // sans extrémité.
  sourceNodeId       String?
  sourceNode         ChainNode?       @relation("chainSourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  sourceAnnotationId String?
  sourceAnnotation   ChainAnnotation? @relation("edgeSourceAnnotation", fields: [sourceAnnotationId], references: [id], onDelete: Cascade)

  targetNodeId       String?
  targetNode         ChainNode?       @relation("chainTargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  targetAnnotationId String?
  targetAnnotation   ChainAnnotation? @relation("edgeTargetAnnotation", fields: [targetAnnotationId], references: [id], onDelete: Cascade)

  technique String? // ex: "Extraction rosin 90µ", "Curing 30j", "Décarboxylation"
  date      DateTime?
  notes     String?

  // Point de courbure optionnel + côté d'accroche manuel — mêmes conventions que
  // GenEdge.waypointX/Y/sourceHandle/targetHandle (PhenoHunt), cf. commentaire là-bas.
  waypointX    Float?
  waypointY    Float?
  sourceHandle String?
  targetHandle String?

  // Même mécanisme que ChainNode.cellData — une liaison peut aussi porter des cellules de
  // pipeline (ex: les jours de curing propres à cette transformation).
  cellData String @default("[]")

  // Même mécanisme que ChainNode.media — photos/vidéos illustrant cette transformation.
  media String @default("[]")

  annotations ChainAnnotation[] @relation("chainAnnotationAnchorEdge")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Pas de @@unique ici : avec 4 colonnes nullables (2 par côté), une contrainte d'unicité SQL
  // laisserait passer des doublons entre deux extrémités "bulle" (NULL est distinct de NULL en
  // SQL). Le refus des doublons est vérifié côté route (cf. production-chains.js).
  @@index([chainId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([sourceAnnotationId])
  @@index([targetAnnotationId])
  @@map("chain_edges")
}

// Modèle ChainAnnotation (carte épinglée sur le canvas — snapshot d'une donnée déjà visible dans
// le panneau latéral d'un nœud/liaison, glissée-déposée pour rester affichée en permanence sans
// avoir à re-sélectionner le nœud/la liaison d'origine. Contrairement à ChainNode.cellData, cette
// carte PEUT porter une vraie référence (nodeId/edgeId) vers l'élément sur lequel elle a été
// déposée — utilisée pour l'ancrer visuellement (ligne de rattachement, suivi si l'élément bouge)
// et est supprimée en cascade si cet élément disparaît. Reste nullable : un dépôt sur le fond vide
// du canvas produit toujours une carte libre, comme avant.)
model ChainAnnotation {
  id      String          @id @default(uuid())
  chainId String
  chain   ProductionChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  nodeId String?
  node   ChainNode? @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  // Nom de relation explicite requis dès qu'il existe plus d'une relation entre ChainAnnotation et
  // ChainEdge — depuis l'ajout de sourceAnnotationId/targetAnnotationId ci-dessous (une bulle peut
  // désormais être elle-même l'extrémité d'une liaison, en plus de son ancrage visuel existant ici).
  edgeId String?
  edge   ChainEdge? @relation("chainAnnotationAnchorEdge", fields: [edgeId], references: [id], onDelete: Cascade)

  // Liaisons (ChainEdge) dont cette bulle est l'extrémité source/cible — distinct de `edge`
  // ci-dessus, qui est l'ancrage visuel pointillé (carte épinglée à côté d'un nœud/liaison), pas
  // une vraie transformation.
  edgeSources ChainEdge[] @relation("edgeSourceAnnotation")
  edgeTargets ChainEdge[] @relation("edgeTargetAnnotation")

  position String // JSON: {x: number, y: number}

  title String // ex: "Culture — S1", "Séparation"
  // Lignes de contenu affichées sur la carte, snapshot au moment du glisser-déposer.
  // JSON: Array<{ label: string, value: string }>
  body  String @default("[]")

  sourceLabel String? // ex: "depuis Soyuz" — contexte affiché en petit, indicatif seulement

  // Référence vers la fiche technique + cellule de pipeline dont cette carte est un snapshot —
  // permet au menu contextuel de la carte de proposer "Aller à la fiche technique" sans avoir à
  // re-parcourir le panneau latéral. Comme sourceLabel, purement indicatif (aucune contrainte FK :
  // la review peut appartenir à une autre table selon reviewType, et peut être supprimée).
  sourceReviewId   String?
  sourceReviewType String?
  pipelineType     String? // 'culture' | 'curing' | 'separation' | 'extraction' | 'general' | 'recipe'
  cellTimestamp    String? // id de la cellule d'origine sur la trame (ex: 'phase-1')

  // "Bulle média" — variante de cette même carte épinglée où le contenu central est une photo/
  // vidéo importée directement sur le canvas (upload ou "Ma bibliothèque") plutôt qu'un snapshot
  // de données textuelles. Les deux usages restent le même modèle : title/body vides pour une
  // bulle média pure, mediaUrl null pour une carte de données classique.
  mediaUrl  String?
  mediaType String? // 'photo' | 'video'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chainId])
  @@index([nodeId])
  @@index([edgeId])
  @@map("chain_annotations")
}

// Modèle GenAnnotation — équivalent PhenoHunt de ChainAnnotation (même principe de carte épinglée
// librement sur le canvas, mêmes deux usages note-texte/bulle-média), lié à GeneticTree/GenNode/
// GenEdge au lieu de ProductionChain/ChainNode/ChainEdge. Duplication volontaire plutôt que
// généralisation du modèle — cf. en-tête UnifiedGeneticsCanvas.jsx pour la justification déjà
// posée sur ce projet (éviter tout risque de régression croisée entre les deux canvas).
model GenAnnotation {
  id     String      @id @default(uuid())
  treeId String
  tree   GeneticTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  nodeId String?
  node   GenNode? @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  edgeId String?
  edge   GenEdge? @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  position String // JSON: {x: number, y: number}

  title String @default("")
  body  String @default("[]") // JSON: Array<{ label: string, value: string }>

  sourceLabel String?

  mediaUrl  String?
  mediaType String? // 'photo' | 'video'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId])
  @@index([nodeId])
  @@index([edgeId])
  @@map("gen_annotations")
}
